# TalentRoute AI — Environment Configuration
# Copy this file to .env and fill in your values

# === LLM Provider ===
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4.1-mini

# === Embedding Model ===
EMBEDDING_MODEL=all-mpnet-base-v2

# === Paths ===
FAISS_INDEX_PATH=app/data/vectorstore/catalog.index
CATALOG_PATH=app/data/raw/SHL-Catalogue.txt

# === Logging ===
LOG_LEVEL=INFO

# === Server ===
HOST=0.0.0.0
PORT=8000
